// schema.prisma — PostgreSQL / Supabase production configuration

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Firm {
  id          String          @id @default(cuid())
  name        String
  stripeSubId String?
  users       User[]
  clients     ClientCompany[]
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  password        String?
  role            Role
  firmId          String?
  firm            Firm?          @relation(fields: [firmId], references: [id])
  clientCompanyId String?
  clientCompany   ClientCompany? @relation(fields: [clientCompanyId], references: [id])
  tasks           Task[]         @relation("UserTasks")
}

model ClientCompany {
  id       String    @id @default(cuid())
  name     String
  ico      String?
  dic      String?
  firmId   String
  firm     Firm      @relation(fields: [firmId], references: [id])
  users    User[]
  invoices Invoice[]
  tasks    Task[]
}

model Invoice {
  id              String        @id @default(cuid())
  clientCompanyId String
  clientCompany   ClientCompany @relation(fields: [clientCompanyId], references: [id])
  fileUrl         String
  type            InvoiceType
  status          DocStatus

  // Fast scalar columns for dashboard queries (avoids JSON scanning)
  issueDate   DateTime?
  dueDate     DateTime?
  totalAmount Float?
  currency    String?

  extractedData Json?    // Full Groq OCR response
  isdocXml      String?  // Generated ISDOC XML payload
  createdAt     DateTime @default(now())
}

model Task {
  id              String         @id @default(cuid())
  title           String
  description     String?
  deadline        DateTime?
  status          TaskStatus
  assigneeId      String?
  assignee        User?          @relation("UserTasks", fields: [assigneeId], references: [id])
  clientCompanyId String?
  clientCompany   ClientCompany? @relation(fields: [clientCompanyId], references: [id])
}

// ---------------------------------------------------------------------------
// Enums (PostgreSQL native — restored from SQLite string workaround)
// ---------------------------------------------------------------------------

enum Role {
  ACCOUNTANT
  CLIENT
}

enum InvoiceType {
  ISSUED
  RECEIVED
}

enum DocStatus {
  PENDING
  EXTRACTED
  APPROVED
  REJECTED
  EXPORTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}
